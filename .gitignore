# Python cache / compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables / secrets
.env
.env.*
*.secret
secrets.*

# Jupyter
.ipynb_checkpoints/
.virtual_documents/

# IPython
profile_default/
ipython_config.py

# Data folders - ignore heavy/raw data folders
data/
datasets/
raw/
processed/
raw_financial_facts_parquet/

# But allow CSV/Parquet outside ignored folders
# Do NOT globally ignore *.csv or *.parquet

# Excel / heavy binary data files
*.xlsx
*.xls
*.h5
*.hdf5
*.feather

# Local databases
*.duckdb
*.duckdb.wal
*.duckdb.tmp
*.db
*.sqlite
*.sqlite3

# Model artifacts
models/
*.pkl
*.pickle
*.joblib
*.onnx

# Generated outputs
outputs/
reports/
figures/
plots/
artifacts/

# Logs
logs/
*.log

# Test / coverage outputs
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Python packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST

# Type checking / linting caches
.mypy_cache/
.pytype/
.pyre/
.ruff_cache/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo
tempCodeRunnerFile.py

# OS files
.DS_Store
Thumbs.db
