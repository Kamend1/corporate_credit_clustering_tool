def compare_to_cluster_profile(scored_row, artifact, segment="Non-financial"):
    segment_artifact = artifact["segment_artifacts"][segment]
    profile = segment_artifact.get("cluster_profile")

    if profile is None:
        raise ValueError("No cluster_profile found in artifact.")

    cluster = int(scored_row["assigned_cluster"])
    cluster_profile = profile.loc[cluster]

    compare_cols = [
        c for c in [
            "log_assets",
            "liabilities_to_assets",
            "debt_to_assets",
            "equity_to_assets",
            "current_ratio",
            "quick_ratio",
            "cash_to_assets",
            "net_income_to_assets",
            "cfo_to_assets",
            "revenue_to_assets",
            "interest_coverage",
            "fcf_to_debt",
            "operating_margin",
            "gross_margin",
        ]
        if c in scored_row.index and c in cluster_profile.index
    ]

    comparison = pd.DataFrame({
        "company_value": scored_row[compare_cols].astype(float),
        "assigned_cluster_median": cluster_profile[compare_cols].astype(float),
    })
    comparison["difference"] = comparison["company_value"] - comparison["assigned_cluster_median"]
    return comparison.round(4)

compare_to_cluster_profile(scored_manual.iloc[0], artifact, segment="Non-financial")





