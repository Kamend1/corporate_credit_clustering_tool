def map_sic_major_division(sic):
    if pd.isna(sic):
        return "Unknown"
    try:
        sic = int(float(sic))
    except Exception:
        return "Unknown"

    if 100 <= sic < 1000:
        return "Agriculture"
    if 1000 <= sic < 1500:
        return "Mining / Energy"
    if 1500 <= sic < 1800:
        return "Construction"
    if 2000 <= sic < 4000:
        return "Manufacturing / Industrials"
    if 4000 <= sic < 5000:
        return "Transportation / Utilities"
    if 5000 <= sic < 6000:
        return "Wholesale / Retail"
    if 6000 <= sic < 6800:
        return "Finance / Insurance / Real Estate"
    if 7000 <= sic < 9000:
        return "Services"
    if 9100 <= sic < 9730:
        return "Public Administration"
    return "Other"

def map_financial_flag(sic):
    if pd.isna(sic):
        return "Unknown"
    try:
        sic = int(float(sic))
    except Exception:
        return "Unknown"
    return "Financial" if 6000 <= sic < 6800 else "Non-financial"


